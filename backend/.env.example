NODE_ENV=development
PORT=3000

# Database
# Supabase: usa la cadena Postgres desde Project Settings > Database.
DATABASE_URL="postgresql://user:password@localhost:5432/techdesk?schema=public"
DIRECT_URL="postgresql://user:password@localhost:5432/techdesk?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production-min-32-chars"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-in-production-min-32-chars"
JWT_EXPIRE_IN=15m
JWT_REFRESH_EXPIRE_IN=7d

# CORS
CORS_ORIGIN="http://localhost:5173,http://localhost:3000"

# Reports
REPORTS_STORAGE_DIR="uploads/reports"

# Email (Fase 2)
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""

# AWS S3 (Para archivos - Fase 2)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET=""
AWS_S3_REGION=""

# Logging
LOG_LEVEL=debug
